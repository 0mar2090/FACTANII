# ==============================
# FacturaPE Backend - Environment
# ==============================

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://facturape:facturape@localhost:5432/facturape

# Redis 7
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Auth
JWT_SECRET=cambiar-esto-a-un-secret-seguro-min-32-caracteres
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=otro-secret-seguro-para-refresh-tokens
JWT_REFRESH_EXPIRATION=7d

# Encryption Key (32 bytes = 64 hex chars) para cifrar certificados y claves SOL
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# SUNAT
SUNAT_ENV=beta
SUNAT_BETA_URL=https://e-beta.sunat.gob.pe/ol-ti-itcpfegem-beta/billService?wsdl
SUNAT_PROD_URL=https://e-factura.sunat.gob.pe/ol-ti-itcpfegem/billService?wsdl
# Credenciales beta de prueba
SUNAT_BETA_RUC=20000000001
SUNAT_BETA_USER=MODDATOS
SUNAT_BETA_PASS=moddatos

# Mercado Pago
MP_ACCESS_TOKEN=TEST-xxx
MP_WEBHOOK_SECRET=xxx

# Resend (email transaccional)
RESEND_API_KEY=re_xxx
EMAIL_FROM=facturas@tudominio.com

# Sentry (opcional, producción)
# SENTRY_DSN=https://xxx@sentry.io/xxx
