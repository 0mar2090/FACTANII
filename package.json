{
  "name": "facturape-backend",
  "version": "0.1.0",
  "description": "Backend SaaS de facturación electrónica SUNAT - NestJS + Fastify + Prisma 7",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test": "vitest",
    "test:e2e": "vitest --config vitest.e2e.config.ts",
    "test:cov": "vitest --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.0.0",
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/swagger": "^11.1.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.1",
    "@sentry/node": "^10.39.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.0",
    "axios": "^1.13.5",
    "bullmq": "^5.66.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.3.7",
    "fastify": "^5.7.4",
    "ioredis": "^5.6.0",
    "mercadopago": "^2.12.0",
    "nestjs-cls": "^4.5.0",
    "node-forge": "^1.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfmake": "^0.3.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.0",
    "rxjs": "^7.8.0",
    "soap": "^1.1.0",
    "xml-crypto": "^6.1.0",
    "xmlbuilder2": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@swc/core": "^1.15.11",
    "@types/adm-zip": "^0.5.0",
    "@types/archiver": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/pdfmake": "^0.2.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  }
}
